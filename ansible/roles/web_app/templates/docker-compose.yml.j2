version: "{{ docker_compose_version }}"

services:
  {{ app_name }}:
    image: {{ web_app_docker_image }}:{{ docker_tag }}
    container_name: {{ app_container_name }}

    ports:
      - "{{ app_port }}:{{ app_internal_port }}"

    restart: {{ web_app_restart_policy }}

    environment:
{% for key, value in web_app_env_vars.items() %}
      {{ key }}: "{{ value }}"
{% endfor %}
